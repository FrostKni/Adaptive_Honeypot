# Adaptive Honeypot Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# AI Model Selection (openai, anthropic, or gemini)
AI_PROVIDER=openai
AI_MODEL=gpt-4

# Gemini Model Options: gemini-pro, gemini-1.5-pro, gemini-1.5-flash
# OpenAI Model Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic Model Options: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307

# Database
DATABASE_URL=sqlite+aiosqlite:///./honeypot.db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API
API_HOST=0.0.0.0
API_PORT=8000

# Honeypot Network
HONEYPOT_NETWORK=honeypot_net
HONEYPOT_SUBNET=172.20.0.0/16

# Monitoring
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Adaptive Settings
ADAPTATION_THRESHOLD=5
ANALYSIS_INTERVAL=60
MAX_HONEYPOTS=10

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
