# Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Application ====================
APP_NAME=Adaptive Honeypot System
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true

# ==================== Database ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=honeypot
DB_PASSWORD=change_me_in_production
DB_NAME=adaptive_honeypot
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ==================== AI Providers ====================
# At least one provider is required
AI_PROVIDER=openai
AI_MODEL=gpt-4-turbo-preview

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini
GEMINI_API_KEY=your-gemini-key

# AI Settings
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.3
AI_CACHE_TTL=3600

# ==================== Security ====================
SECURITY_JWT_SECRET=change-me-to-secure-random-string
SECURITY_JWT_ALGORITHM=HS256
SECURITY_JWT_EXPIRE_MINUTES=60

# Rate Limiting
SECURITY_RATE_LIMIT_REQUESTS=100
SECURITY_RATE_LIMIT_WINDOW=60

# CORS (comma-separated)
SECURITY_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==================== Honeypot ====================
HONEYPOT_NETWORK_NAME=honeypot_net
HONEYPOT_SUBNET=172.20.0.0/16
HONEYPOT_MAX_INSTANCES=20
HONEYPOT_DEFAULT_PORT_START=2222
HONEYPOT_DEFAULT_PORT_END=2300

# Adaptation
HONEYPOT_ADAPTATION_THRESHOLD=5
HONEYPOT_ANALYSIS_INTERVAL=60
HONEYPOT_MAX_ADAPTATIONS_PER_HOUR=10

# Sessions
HONEYPOT_SESSION_TIMEOUT=3600
HONEYPOT_MAX_SESSIONS=50

# ==================== Monitoring ====================
MONITORING_PROMETHEUS_PORT=9090
MONITORING_ENABLE_METRICS=true
MONITORING_LOG_LEVEL=INFO
MONITORING_HEALTH_CHECK_INTERVAL=30

# ==================== Alerting ====================
# Email
ALERT_SMTP_HOST=smtp.example.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=alerts@example.com
ALERT_SMTP_PASSWORD=smtp-password
ALERT_EMAIL_RECIPIENTS=admin@example.com,security@example.com

# Slack
ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Discord
ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# Generic Webhook
ALERT_WEBHOOK_URL=https://your-webhook-endpoint.com/alerts
# ALERT_WEBHOOK_HEADERS={"Authorization": "Bearer token"}

# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=8000