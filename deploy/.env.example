# Environment Variables Template for Adaptive Honeypot System
# Copy this file to .env and fill in the values

# ========================================
# Application Settings
# ========================================
APP_NAME=Adaptive Honeypot System
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ========================================
# Security Settings
# ========================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-min-32-characters-here
JWT_SECRET=your-jwt-secret-min-32-characters-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ========================================
# Database Settings
# ========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=honeypot
DB_PASSWORD=your-secure-postgres-password
DB_NAME=adaptive_honeypot
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ========================================
# Redis Settings
# ========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password

# ========================================
# AI Provider Settings
# ========================================
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
AI_MODEL=gpt-4
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000

# ========================================
# Threat Intelligence APIs
# ========================================
VIRUSTOTAL_API_KEY=your-virustotal-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# ========================================
# Alerting Configuration
# ========================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your-smtp-password
ALERT_EMAIL=security@example.com

# ========================================
# CORS Settings
# ========================================
CORS_ORIGINS=["https://honeypot.example.com"]

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ========================================
# Monitoring Settings
# ========================================
METRICS_ENABLED=true
TRACING_ENABLED=true
TRACING_SAMPLE_RATE=0.1

# ========================================
# Grafana Settings
# ========================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-secure-grafana-password
GRAFANA_URL=https://honeypot.example.com/grafana

# ========================================
# Container Image Tags
# ========================================
VERSION=latest
IMAGE_TAG=v1.0.0